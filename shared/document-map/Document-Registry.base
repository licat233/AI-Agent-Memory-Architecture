filters:
  and:
    - 'file.ext == "md"'

properties:
  file.path:
    displayName: "Document"
  type:
    displayName: "Type"
  memory_layer:
    displayName: "Memory Layer"
  status:
    displayName: "Status"
  authority:
    displayName: "Authority"
  write_policy:
    displayName: "Write Policy"
  author_agent:
    displayName: "Author Agent"
  confidence:
    displayName: "Confidence"
  owner:
    displayName: "Owner"
  updated:
    displayName: "Updated"
  review_date:
    displayName: "Review Date"
  expires_at:
    displayName: "Expires"
  retrieval_scope:
    displayName: "Retrieval Scope"

views:
  - type: table
    name: "Current Authority"
    filters:
      and:
        - 'authority == "ssot" || authority == "approved"'
        - 'status != "archived"'
        - 'status != "superseded"'
        - 'status != "deprecated"'
        - 'status != "expired"'
    order:
      - file.path
      - type
      - memory_layer
      - status
      - authority
      - owner
      - updated
      - review_date

  - type: table
    name: "Needs Review"
    filters:
      or:
        - 'status == "needs_review"'
        - 'status == "pending"'
        - 'status == "candidate"'
    order:
      - file.path
      - type
      - memory_layer
      - status
      - authority
      - confidence
      - author_agent
      - updated
      - review_date

  - type: table
    name: "Expiring"
    filters:
      and:
        - 'expires_at != null'
        - 'status != "archived"'
        - 'status != "superseded"'
    order:
      - file.path
      - type
      - memory_layer
      - status
      - authority
      - expires_at
      - review_date
      - owner

  - type: table
    name: "Proposals And Conflicts"
    filters:
      or:
        - 'type == "proposal"'
        - 'type == "conflict"'
        - 'type == "conflict_review"'
        - 'memory_layer == "proposals"'
    order:
      - file.path
      - type
      - status
      - author_agent
      - confidence
      - updated

  - type: table
    name: "By Memory Layer"
    groupBy:
      property: memory_layer
      direction: ASC
    order:
      - file.path
      - type
      - status
      - authority
      - write_policy
      - updated

  - type: table
    name: "Historical"
    filters:
      or:
        - 'status == "archived"'
        - 'status == "superseded"'
        - 'status == "deprecated"'
        - 'status == "expired"'
        - 'memory_layer == "archive"'
        - 'retrieval_scope == "historical_only"'
    order:
      - file.path
      - type
      - memory_layer
      - status
      - authority
      - updated
